# SkyPortal Environment Configuration
# Copy this file to .env and fill in your values

# Database
DB_PASSWORD=change_me_to_a_strong_password

# JWT Secret (generate with: openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret

# The public IP or hostname of your VPS
# Lab containers will be accessible at http://LAB_HOST:PORT
LAB_HOST=your-vps-ip-or-domain.com

# Port range for lab containers (must be open in firewall)
LAB_PORT_MIN=10000
LAB_PORT_MAX=11000

# Lab timeout (minutes)
LAB_TIMEOUT_MINUTES=30

# Frontend URL (for CORS)
FRONTEND_URL=http://your-vps-ip-or-domain.com
